FROM nvcr.io/nvidia/pytorch:25.12-py3

LABEL name="hunyuan3d21-spark-arm64" maintainer="hunyuan3d21"

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYOPENGL_PLATFORM=egl
ENV TORCH_CUDA_ARCH_LIST="8.7;8.9;9.0"

WORKDIR /workspace

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    wget \
    vim \
    unzip \
    curl \
    pkg-config \
    cmake \
    libeigen3-dev \
    libcgal-dev \
    python3-dev \
    python3-setuptools \
    libglvnd0 \
    libgl1 \
    libglx0 \
    libegl1 \
    libgles2 \
    libglvnd-dev \
    libgl1-mesa-dev \
    libegl1-mesa-dev \
    libgles2-mesa-dev \
    libglib2.0-0 \
    libxrender1 \
    libxext6 \
    libsm6 \
    libxkbcommon-x11-0 \
    mesa-utils-extra && \
    rm -rf /var/lib/apt/lists/*

COPY . /workspace/Hunyuan3D-2.1
WORKDIR /workspace/Hunyuan3D-2.1

# Use PyTorch already provided by base image and avoid reinstalling
# torch/torchvision/torchaudio from requirements.
RUN if [ ! -f /workspace/Hunyuan3D-2.1/requirements.txt ]; then \
        echo "ERROR: requirements.txt not found in image." && \
        echo "Build from repo root, for example:" && \
        echo "  docker build -f docker/Dockerfile.spark.arm64 -t hunyuan3d21:spark-arm64 ." && \
        exit 1; \
    fi && \
    grep -viE '^(torch|torchvision|torchaudio)([<>=].*)?$' /workspace/Hunyuan3D-2.1/requirements.txt > /tmp/requirements.spark_arm64.txt && \
    pip install --no-cache-dir -r /tmp/requirements.spark_arm64.txt

RUN cd hy3dpaint/custom_rasterizer && \
    export CUDA_NVCC_FLAGS="-allow-unsupported-compiler" && \
    pip install -e .

RUN cd hy3dpaint/DifferentiableRenderer && \
    bash compile_mesh_painter.sh

RUN mkdir -p hy3dpaint/ckpt && \
    wget https://github.com/xinntao/Real-ESRGAN/releases/download/v0.1.0/RealESRGAN_x4plus.pth -P hy3dpaint/ckpt

RUN sed -i 's/self\.multiview_cfg_path = "cfgs\/hunyuan-paint-pbr\.yaml"/self.multiview_cfg_path = "hy3dpaint\/cfgs\/hunyuan-paint-pbr.yaml"/' hy3dpaint/textureGenPipeline.py

RUN sed -i 's/custom_pipeline = config\.custom_pipeline/custom_pipeline = os.path.join(os.path.dirname(__file__),"..","hunyuanpaintpbr")/' hy3dpaint/utils/multiview_utils.py

RUN mkdir -p openai_cache

EXPOSE 8082

CMD ["python", "openai_compatible_api.py", "--host", "0.0.0.0", "--port", "8082"]
