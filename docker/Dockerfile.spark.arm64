FROM nvcr.io/nvidia/pytorch:24.08-py3

LABEL name="hunyuan3d21-spark-arm64" maintainer="hunyuan3d21"

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYOPENGL_PLATFORM=egl
ENV TORCH_CUDA_ARCH_LIST="8.7;8.9;9.0"

WORKDIR /workspace

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    wget \
    vim \
    unzip \
    curl \
    pkg-config \
    cmake \
    libeigen3-dev \
    libcgal-dev \
    python3-dev \
    python3-setuptools \
    libglvnd0 \
    libgl1 \
    libglx0 \
    libegl1 \
    libgles2 \
    libglvnd-dev \
    libgl1-mesa-dev \
    libegl1-mesa-dev \
    libgles2-mesa-dev \
    libglib2.0-0 \
    libxrender1 \
    libxext6 \
    libsm6 \
    libxkbcommon-x11-0 \
    mesa-utils-extra && \
    rm -rf /var/lib/apt/lists/*

COPY . /workspace/Hunyuan3D-2.1
WORKDIR /workspace/Hunyuan3D-2.1

RUN python - <<'PY'
import sys
print('Python version:', sys.version)
if sys.version_info[:2] != (3, 10):
    raise SystemExit('ERROR: This Dockerfile expects Python 3.10 to match project requirements pins.')
PY

# Use PyTorch already provided by base image and avoid reinstalling
# torch/torchvision/torchaudio from requirements.
RUN if [ ! -f /workspace/Hunyuan3D-2.1/requirements.txt ]; then \
        echo "ERROR: requirements.txt not found in image." && \
        echo "Build from repo root, for example:" && \
        echo "  docker build -f docker/Dockerfile.spark.arm64 -t hunyuan3d21:spark-arm64 ." && \
        exit 1; \
    fi

RUN python - <<'PY'
from pathlib import Path

src = Path('/workspace/Hunyuan3D-2.1/requirements.txt')
dst = Path('/tmp/requirements.spark_arm64.txt')

out_lines = []
for raw_line in src.read_text(encoding='utf-8').splitlines():
    line = raw_line.strip()
    lower = line.lower()
    if lower.startswith('--extra-index-url') or lower.startswith('--index-url'):
        continue
    if lower.startswith('torch==') or lower.startswith('torchvision==') or lower.startswith('torchaudio=='):
        continue
    if lower.startswith('bpy=='):
        continue
    if lower.startswith('pymeshlab=='):
        out_lines.append('pymeshlab==2025.7.post1')
        continue
    out_lines.append(raw_line)

dst.write_text('\n'.join(out_lines) + '\n', encoding='utf-8')
print('Wrote', dst)
PY

RUN \
    pip install --no-cache-dir \
    --index-url https://pypi.org/simple \
    --extra-index-url https://pypi.ngc.nvidia.com \
    --retries 12 \
    --timeout 180 \
    --prefer-binary \
    -r /tmp/requirements.spark_arm64.txt

# bpy on ARM64 is generally not reliably available via pip; install with conda.
RUN conda install -y -c conda-forge "bpy>=4.0,<5.0" && \
    conda clean -afy

RUN cd hy3dpaint/custom_rasterizer && \
    export CUDA_NVCC_FLAGS="-allow-unsupported-compiler" && \
    pip install -e .

RUN cd hy3dpaint/DifferentiableRenderer && \
    bash compile_mesh_painter.sh

RUN mkdir -p hy3dpaint/ckpt && \
    wget https://github.com/xinntao/Real-ESRGAN/releases/download/v0.1.0/RealESRGAN_x4plus.pth -P hy3dpaint/ckpt

RUN sed -i 's/self\.multiview_cfg_path = "cfgs\/hunyuan-paint-pbr\.yaml"/self.multiview_cfg_path = "hy3dpaint\/cfgs\/hunyuan-paint-pbr.yaml"/' hy3dpaint/textureGenPipeline.py

RUN sed -i 's/custom_pipeline = config\.custom_pipeline/custom_pipeline = os.path.join(os.path.dirname(__file__),"..","hunyuanpaintpbr")/' hy3dpaint/utils/multiview_utils.py

RUN mkdir -p openai_cache

EXPOSE 8082

CMD ["python", "openai_compatible_api.py", "--host", "0.0.0.0", "--port", "8082"]
